{
  "mcpServers": {
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp"
    },
    "reader": {
      "command": "node",
      "args": [
        "$HOME/.claude/mcp-servers/reader-mcp/dist/index.js"
      ]
    },
    "markdown2pdf": {
      "command": "npx",
      "args": [
        "-y",
        "markdown2pdf-mcp@latest"
      ]
    },
    "mcp-mermaid": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-mermaid"
      ]
    },
    "excel": {
      "command": "uvx",
      "args": [
        "excel-mcp-server",
        "stdio"
      ]
    },
    "telegram": {
      "command": "uv",
      "args": [
        "--directory",
        "$HOME/.claude/mcp-servers/telegram-mcp",
        "run",
        "main.py"
      ]
    },
    "apify": {
      "command": "npx",
      "args": [
        "-y",
        "@apify/actors-mcp-server@latest"
      ],
      "env": {
        "APIFY_TOKEN": "YOUR_APIFY_TOKEN_HERE"
      }
    },
    "ssh-mcp-server": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "ssh-mcp-server"
      ],
      "env": {}
    }
  },
  "autoUpdates": false,
  "teammateMode": "tmux"
}
